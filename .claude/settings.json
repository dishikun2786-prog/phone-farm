{
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(git *)",
      "Bash(tsc *)",
      "Bash(tsx *)",
      "Bash(docker *)",
      "Bash(docker compose *)",
      "Bash(adb *)",
      "Bash(scrcpy *)",
      "Bash(curl *)",
      "Bash(mkdir *)",
      "PowerShell(Get-*)",
      "PowerShell(New-*)",
      "PowerShell(Remove-*)",
      "PowerShell(Write-*)",
      "PowerShell(Expand-*)",
      "PowerShell(Set-*)",
      "PowerShell(npm *)",
      "PowerShell(go *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Running: ${CLAUDE_TOOL_COMMAND}\""
          }
        ]
      }
    ]
  }
}
