# ===== 本地控制服务器环境变量 =====

# JWT 密钥
JWT_SECRET=change-me-in-production

# 设备认证 token（与 VPS 中继的 DEVICE_AUTH_TOKEN 一致）
DEVICE_AUTH_TOKEN=device-auth-token-change-me

# ── VPS 桥接配置（必填）──
# VPS 中继服务器 WebSocket 地址
BRIDGE_RELAY_URL=ws://your-vps-ip-or-domain:80/ws/control

# VPS 中继控制端认证 token（与 VPS 的 CONTROL_TOKEN 一致）
BRIDGE_CONTROL_TOKEN=change-me-to-a-random-string-at-least-32-chars
