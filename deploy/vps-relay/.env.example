# ===== VPS Relay Server 环境变量 =====

# WebSocket 监听端口
RELAY_PORT=8499

# 监听地址
RELAY_HOST=0.0.0.0

# 控制端认证 token（本地服务器连接 VPS 时使用）
CONTROL_TOKEN=change-me-to-a-random-string-at-least-32-chars

# 手机设备认证 token（手机 APK 连接 VPS 时使用）
DEVICE_AUTH_TOKEN=change-me-to-another-random-string

# JWT 密钥（Dashboard 前端认证用）
JWT_SECRET=change-me-to-a-random-jwt-secret

# UDP 中继端口（音视频帧转发）
UDP_RELAY_PORT=8444

# AI 协同认证 token（Claude Code 和 DeepSeek Worker 使用）
AI_AUTH_TOKEN=change-me-to-another-random-string-32chars
