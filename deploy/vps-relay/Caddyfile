# Caddy configuration for openedskill.com
# Cloudflare handles public SSL; origin uses self-signed cert

sr.openedskill.com {
	tls internal

	handle /socket.io/* {
		reverse_proxy 127.0.0.1:3000
	}

	reverse_proxy 127.0.0.1:3001
	encode gzip
	header {
		X-Forwarded-Proto https
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
	}
}

ht.openedskill.com {
	tls internal
	reverse_proxy localhost:3002
	encode gzip
	header {
		X-Forwarded-Proto https
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
	}
}

phone.openedskill.com {
	tls internal

	# WebSocket endpoints — all go to relay at 8499 (场景A: VPS relay bridges to local control)
	# Long timeouts for persistent WebSocket connections
	handle /ws/* {
		reverse_proxy 127.0.0.1:8499 {
			header_up X-Forwarded-Proto https
		}
	}

	# API requests — proxy to relay which forwards to local control server
	handle /api/* {
		reverse_proxy 127.0.0.1:8499 {
			header_up X-Forwarded-Proto https
		}
	}

	# Health check — also via relay
	handle /health {
		reverse_proxy 127.0.0.1:8499
	}

	# Static dashboard files + SPA fallback — relay serves dashboard/dist/
	reverse_proxy 127.0.0.1:8499
	encode gzip
	header {
		X-Forwarded-Proto https
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
	}
}
